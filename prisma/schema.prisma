// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model OptimizationHistory {
  id                 String @id @default(cuid())
  shopDomain         String
  productId          String
  productTitleBefore String
  productTitleAfter  String

  seoScoreBefore   Int?
  seoScoreAfter    Int?
  impactDelta      Int?
  issueCountBefore Int?
  issueCountAfter  Int?

  changeType   String @default("title")
  source       String @default("manual")
  decisionMode String @default("suggest")
  status       String @default("applied")

  whyText         String?
  outcomeText     String?
  actionText      String?
  rawIssuesJson   String?
  rawDecisionJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopDomain, createdAt(sort: Desc)])
  @@index([shopDomain, productId, createdAt(sort: Desc)])
  @@index([shopDomain, source, createdAt(sort: Desc)])
  @@index([shopDomain, status, createdAt(sort: Desc)])
}

model AutoOptimizeSettings {
  id                      String    @id @default(cuid())
  shopDomain              String    @unique
  enabled                 Boolean   @default(false)
  mode                    String    @default("suggest")
  lastRunAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  optimizeBelowScore      Int       @default(70)
  optimizeShortTitle      Boolean   @default(true)
  optimizeWeakDescription Boolean   @default(true)

  prioritizeLowScore        Boolean @default(true)
  prioritizeWeakDescription Boolean @default(true)

  maxProductsPerRun Int @default(5)
  runFrequencyDays  Int @default(7)
}

model GrowthAutomationRule {
  id         String @id @default(cuid())
  shopDomain String @unique

  optimizeBelowScore      Int     @default(70)
  optimizeShortTitle      Boolean @default(true)
  optimizeWeakDescription Boolean @default(true)
  optimizeNewProductsOnly Boolean @default(false)

  prioritizeLowScore        Boolean @default(true)
  prioritizeNewProducts     Boolean @default(true)
  prioritizeWeakDescription Boolean @default(true)

  maxProductsPerRun Int    @default(10)
  runMode           String @default("suggest") // suggest | auto
  runFrequencyDays  Int    @default(7)

  focusMode String @default("balanced") // seo | conversion | balanced

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
